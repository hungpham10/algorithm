
---
import '../styles/global.css';
import GoldSummary from '../components/GoldSummary.svelte';
import TableHead from '../components/TableHead.astro';
import TableRow from '../components/TableRow.astro';

// 1. Kiểm soát render quảng cáo từ môi trường build (SSG)
// Astro sẽ đọc giá trị này khi build. Nếu là 'false', code quảng cáo sẽ không tồn tại trong file HTML cuối cùng.
const SHOW_ADS = import.meta.env.SHOW_ADS === 'true';

// 2. Định nghĩa endpoint
const GRAPHQL_ENDPOINT = "https://lighttrading.pp.ua/api/investing/v2/astra-render";

// 3. Fetch dữ liệu từ GraphQL
let data;
try {
  const response = await fetch(GRAPHQL_ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetGoldData {
	  goldMarketList(after: 0, limit: 10) {
            type
            buy
            sell
            diffBuy
            diffSell
            yesterdayBuy
            yesterdaySell
            trend
            trendData
          }
        }
      `
    }),
  });
  const resJson = await response.json();
  data = resJson.data;
} catch (e) {
  console.error("Fetch error:", e);
}

// 4. Gán dữ liệu (fallback)
const summaryData = data?.goldSummary || {
  vn: { buy: "0", sell: "0", diffBuy: "-", diffSell: "-", percentBuy: "0%", percentSell: "0%", gap: "0" },
  world: { price: "0", diff: "-", percent: "0%", convertedVnd: "0" }
};

const goldList = data?.goldMarketList || [];

// 5. Xử lý thời gian
const now = new Date();
const currentDate = `${now.getDate()}/${now.getMonth() + 1}/${now.getFullYear()}`;
const yesterdayDate = `${now.getDate() - 1}/${now.getMonth() + 1}/${now.getFullYear()}`;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng giá vàng</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />  
    <link rel="alternate icon" href="/favicon.ico" />
  </head>
  
  <body class="bg-[#f8f9fa] text-gray-900 antialiased">
    
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
      <div class="max-w-[1440px] mx-auto px-4 h-14 flex items-center justify-between">
        
        <div class="flex items-center gap-8">
          <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <img src="/logo.svg" alt="Logo" class="h-8 w-auto md:h-9" />
          </a>

          <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-500">
            <a href="#" class="text-orange-600 border-b-2 border-orange-600 h-14 flex items-center mt-[2px]">Bảng giá</a>
            <a href="#" class="hover:text-gray-900 transition-colors">Biểu đồ</a>
            <a href="#" class="hover:text-gray-900 transition-colors">Tin tức</a>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <div class="text-[11px] font-medium text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full uppercase tracking-wider">
            Dữ liệu trực tuyến
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-[1440px] mx-auto px-3 py-4 md:py-6 grid grid-cols-1 lg:grid-cols-12 gap-4">

      <main class={SHOW_ADS ? "lg:col-span-9 space-y-4" : "lg:col-span-12 space-y-4"}>

        <GoldSummary initialData={summaryData} client:load />

        <div class="bg-white shadow-sm border border-gray-200 rounded-md overflow-hidden">
          <header class="p-3 md:p-4 border-b border-gray-100 flex justify-between items-center bg-white">
            <div class="flex items-baseline gap-2">
              <h1 class="text-lg md:text-xl font-bold text-gray-800 tracking-tight">Giá vàng hôm nay</h1>
              <span class="text-gray-400 italic text-[10px] md:text-xs">| triệu đồng/lượng</span>
            </div>
            <div class="text-[10px] md:text-[11px] text-gray-400 font-medium">
              Cập nhật: {currentDate}
            </div>
          </header>

          <div class="overflow-x-auto relative scrollbar-hide">
            <table class="w-full border-collapse min-w-[600px]">
              <TableHead currentDate={currentDate} yesterdayDate={yesterdayDate} />
              <tbody class="divide-y divide-gray-50">
                {goldList.length > 0 ? (
                  goldList.map((item) => <TableRow data={item} />)
                ) : (
                  <tr><td colspan="5" class="p-10 text-center text-gray-400 italic">Đang cập nhật dữ liệu...</td></tr>
                )}
              </tbody>
            </table>
          </div>

          <footer class="p-3 bg-gray-50/50 flex justify-between text-[11px] text-gray-400 px-5 italic border-t border-gray-100">
            <div>▲ tăng, ▼ giảm so với hôm qua</div>
            <div class="hidden sm:block">Nguồn: SJC, PNJ, Kitco</div>
          </footer>
        </div>
      </main>

      {SHOW_ADS && (
        <aside class="hidden lg:block lg:col-span-3 space-y-4">
          <div class="sticky top-[74px] space-y-4">
            <div class="bg-white p-2 shadow-sm border border-gray-200 rounded-md">
              <div class="bg-gray-50 h-[250px] flex flex-col items-center justify-center text-gray-300 border border-dashed border-gray-200">
                <p class="text-[9px] uppercase font-bold tracking-widest">Advertisement</p>
              </div>
            </div>
            <div class="bg-white p-4 shadow-sm border border-gray-200 rounded-md">
              <h4 class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-widest border-b pb-2">Tin nhanh</h4>
              <ul class="space-y-3">
                <li class="text-sm leading-snug hover:text-orange-600 cursor-pointer text-gray-600 transition-colors italic line-clamp-2 underline decoration-gray-100 underline-offset-4">
                  • Vàng thế giới lập đỉnh mới sáng nay...
                </li>
                <li class="text-sm leading-snug hover:text-orange-600 cursor-pointer text-gray-600 transition-colors italic line-clamp-2 underline decoration-gray-100 underline-offset-4">
                  • Lãi suất ngân hàng tiếp tục giảm...
                </li>
              </ul>
            </div>
          </div>
        </aside>
      )}

    </div>
    
    <div class="h-10 lg:hidden"></div>

  </body>
</html>
