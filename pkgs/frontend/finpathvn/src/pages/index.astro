
---
import '../styles/global.css';
import GoldSummary from '../components/GoldSummary.svelte';
import TableHead from '../components/TableHead.astro';
import TableRow from '../components/TableRow.astro';

// 1. Kiểm soát render quảng cáo từ môi trường build (SSG)
// Astro sẽ đọc giá trị này khi build. Nếu là 'false', code quảng cáo sẽ không tồn tại trong file HTML cuối cùng.
const SHOW_ADS = import.meta.env.SHOW_ADS === 'true';

// 2. Định nghĩa endpoint
const GRAPHQL_ENDPOINT = "https://lighttrading.pp.ua/api/investing/v2/astra-render";

// 3. Fetch dữ liệu từ GraphQL
let data;
try {
  const response = await fetch(GRAPHQL_ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetGoldData {
          goldMarketList(after: 0, limit: 10) {
            type
            buy
            sell
            diffBuy
            diffSell
            yesterdayBuy
            yesterdaySell
            trend
            trendData
          }
        }
      `
    }),
  });
  const resJson = await response.json();
  data = resJson.data;
} catch (e) {
  console.error("Fetch error:", e);
}

// 4. Gán dữ liệu (fallback)
const summaryData = data?.goldSummary || {
  vn: { buy: "0", sell: "0", diffBuy: "-", diffSell: "-", percentBuy: "0%", percentSell: "0%", gap: "0" },
  world: { price: "0", diff: "-", percent: "0%", convertedVnd: "0" }
};

const goldList = data?.goldMarketList || [];

// 5. Xử lý thời gian
const now = new Date();
const currentDate = `${now.getDate()}/${now.getMonth() + 1}/${now.getFullYear()}`;
const yesterdayDate = `${now.getDate() - 1}/${now.getMonth() + 1}/${now.getFullYear()}`;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng giá vàng</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />  
    <link rel="alternate icon" href="/favicon.ico" />
  </head>
  <body class="bg-gray-100 p-2 md:p-6 pb-20 lg:pb-6">
    <nav class="max-w-[1440px] mx-auto mb-4 px-2 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo.svg" alt="Logo" class="h-10 w-auto md:h-12" />
      </a>
      
      <div class="text-[11px] text-gray-400 italic">Dữ liệu thời gian thực</div>
    </nav>

    <div class="max-w-[1440px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-5">

      <main class={SHOW_ADS ? "lg:col-span-9 space-y-4" : "lg:col-span-12 space-y-4"}>

        <GoldSummary initialData={summaryData} client:load />

        <div class="bg-white shadow-sm border border-gray-200 rounded-sm">
          <header class="p-4 border-b border-gray-100 flex justify-between items-center bg-white">
            <div class="flex items-baseline gap-2">
              <h1 class="text-xl md:text-2xl font-medium text-gray-800 tracking-tight text-nowrap">Giá vàng hôm nay</h1>
              <span class="text-gray-400 italic text-[10px] md:text-xs text-nowrap">| triệu đồng/lượng</span>
            </div>
            <div class="text-[10px] md:text-[12px] text-gray-500 font-medium bg-gray-50 px-2 py-1 rounded">
              Cập nhật: {currentDate}
            </div>
          </header>

          <div class="overflow-x-auto relative scrollbar-hide">
            <table class="w-full border-collapse min-w-[600px]">
              <TableHead currentDate={currentDate} yesterdayDate={yesterdayDate} />
              <tbody>
                {goldList.map((item) => <TableRow data={item} />)}
              </tbody>
            </table>
          </div>

          <footer class="p-3 bg-gray-50/50 flex justify-between text-[11px] text-gray-400 px-5 italic">
            <div>▲ tăng, ▼ giảm so với hôm qua</div>
            <div class="hidden sm:block">Nguồn: SJC, PNJ, Kitco</div>
          </footer>
        </div>
      </main>

      {SHOW_ADS && (
        <aside class="hidden lg:block lg:col-span-3">
          <div class="sticky top-6 space-y-4">

            <div class="bg-white p-2 shadow-sm border border-gray-200 rounded-sm">
              <div class="bg-gray-100 h-[250px] flex flex-col items-center justify-center text-gray-400 border border-dashed border-gray-300">
                <p class="text-[10px] uppercase font-bold mb-1">Quảng cáo</p>
                <p class="text-xs">Banner 300x250</p>
              </div>
            </div>

            <div class="bg-white p-4 shadow-sm border border-gray-200 rounded-sm">
                <h4 class="text-sm font-bold text-gray-700 mb-3 uppercase border-b pb-2 text-center">Tin nhanh</h4>
                <ul class="space-y-3">
                  <li class="text-[14px] leading-snug hover:text-blue-600 cursor-pointer text-gray-600 font-medium italic">
                    • Vàng thế giới lập đỉnh mới sáng nay...
                  </li>
                  <li class="text-[14px] leading-snug hover:text-blue-600 cursor-pointer text-gray-600 font-medium italic">
                    • Lãi suất ngân hàng tiếp tục giảm...
                  </li>
                </ul>
            </div>

            <div class="bg-gray-200 h-[500px] flex items-center justify-center text-gray-400 text-xs border-2 border-dashed border-gray-300 rounded-sm uppercase font-bold text-center p-4">
              Banner dọc 160x600
            </div>

          </div>
        </aside>
      )}

    </div>

    {SHOW_ADS && (
      <div class="lg:hidden fixed bottom-0 left-0 w-full z-50 bg-white border-t border-gray-200 shadow-[0_-2px_10px_rgba(0,0,0,0.1)] p-1.5 pb-safe">
        <div class="max-w-md mx-auto relative">
          <button
            onclick="this.parentElement.parentElement.style.display='none'"
            class="absolute -top-4 -right-1 bg-gray-800 text-white text-[12px] rounded-full w-6 h-6 flex items-center justify-center border-2 border-white shadow-md active:scale-90 transition-transform"
            aria-label="Đóng quảng cáo"
          >
            ✕
          </button>

          <div class="bg-gray-100 h-[55px] flex items-center justify-center text-gray-400 border border-dashed border-gray-300 rounded-sm">
              <div class="text-center">
                <p class="text-[9px] uppercase font-bold leading-none text-gray-500">Quảng cáo tài trợ</p>
                <p class="text-[12px] font-medium text-gray-600 italic">Banner luôn hiển thị 320x50</p>
              </div>
          </div>
        </div>
      </div>
    )}

  </body>
</html>
