---
import '../styles/global.css';
import GoldSummary from '../components/GoldSummary.svelte';
import TableHead from '../components/TableHead.astro';
import TableRow from '../components/TableRow.astro';

// 1. Kiểm soát render quảng cáo
const SHOW_ADS = import.meta.env.SHOW_ADS === 'true';

// 2. Định nghĩa endpoint
const GRAPHQL_ENDPOINT = "https://lighttrading.pp.ua/api/investing/v2/astra-render";

// 3. Fetch dữ liệu
let data;
try {
  const response = await fetch(GRAPHQL_ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetGoldData {
          goldMarketList(after: 0, limit: 10) {
            type
            buy
            sell
            diffBuy
            diffSell
            yesterdayBuy
            yesterdaySell
            trend
	    trendData
	    livePrice
          }
        }
      `
    }),
  });
  const resJson = await response.json();
  data = resJson.data;
} catch (e) {
  console.error("Fetch error:", e);
}

const summaryData = data?.goldSummary || {
  vn: { buy: "0", sell: "0", diffBuy: "-", diffSell: "-", percentBuy: "0%", percentSell: "0%", gap: "0" },
  world: { price: "0", diff: "-", percent: "0%", convertedVnd: "0" }
};
const goldList = data?.goldMarketList || [];

const now = new Date();
const currentDate = `${now.getDate()}/${now.getMonth() + 1}/${now.getFullYear()}`;
const yesterdayDate = `${now.getDate() - 1}/${now.getMonth() + 1}/${now.getFullYear()}`;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng giá vàng trực tuyến</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
  </head>

  <body class="bg-[#f3f4f6] text-gray-900 antialiased">
    <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm">
      <div class="max-w-[1440px] mx-auto px-4 h-16 flex items-center justify-between">

        <a href="/" class="flex items-center hover:opacity-90 transition-opacity">
          <img
            src="/logo.svg"
            alt="Logo"
            class="h-12 w-auto md:h-14 object-contain"
          />
        </a>

        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1 rounded-full border border-green-100 shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
            </span>
            <span class="text-[11px] font-bold uppercase tracking-wider">Live Data</span>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-[1440px] mx-auto px-3 py-4 md:py-6 grid grid-cols-1 lg:grid-cols-12 gap-5">

      <main class={SHOW_ADS ? "lg:col-span-9 space-y-4" : "lg:col-span-12 space-y-4"}>

        <GoldSummary initialData={summaryData} client:idle />
        <div class="bg-white shadow-md border border-gray-200 rounded-lg overflow-hidden">
          <header class="p-4 md:p-5 border-b border-gray-100 flex justify-between items-center bg-white">
            <div class="flex items-baseline gap-2">
              <h1 class="text-xl md:text-2xl font-bold text-gray-800 tracking-tight">Giá vàng hôm nay</h1>
              <span class="text-gray-400 italic text-xs md:text-sm">| triệu đồng/lượng</span>
            </div>
            <div class="text-xs md:text-sm text-gray-500 font-medium bg-gray-50 px-2 py-1 rounded border border-gray-100">
              {currentDate}
            </div>
          </header>

          <div class="overflow-x-auto relative scrollbar-hide">
            <table class="w-full border-collapse min-w-[600px]">
              <TableHead currentDate={currentDate} yesterdayDate={yesterdayDate} />
              <tbody class="divide-y divide-gray-100">
                {goldList.length > 0 ? (
                  goldList.map((item) => <TableRow data={item} />)
                ) : (
                  <tr><td colspan="5" class="p-10 text-center text-gray-400 italic">Đang cập nhật dữ liệu...</td></tr>
                )}
              </tbody>
            </table>
          </div>

          <footer class="p-3 bg-gray-50/50 flex justify-between text-[11px] text-gray-400 px-5 italic border-t border-gray-100">
            <div>▲ tăng, ▼ giảm so với hôm qua</div>
            <div class="hidden sm:block">Nguồn: SJC, PNJ, Kitco</div>
          </footer>
        </div>
      </main>

      {SHOW_ADS && (
        <aside class="hidden lg:block lg:col-span-3">
          <div class="sticky top-20 space-y-4">
            <div class="bg-white p-2 shadow-md border border-gray-200 rounded-lg">
              <div class="bg-gray-100 h-[250px] flex flex-col items-center justify-center text-gray-400 border border-dashed border-gray-300 rounded">
                <p class="text-[10px] uppercase font-bold mb-1 tracking-widest">Quảng cáo</p>
                <p class="text-xs">300 x 250</p>
              </div>
            </div>

            <div class="bg-white p-5 shadow-md border border-gray-200 rounded-lg">
                <h4 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wider border-b pb-2">Tin nhanh thị trường</h4>
                <ul class="space-y-4">
                  <li class="text-sm text-gray-600 hover:text-blue-600 cursor-pointer transition-colors leading-snug">• <b>Vàng thế giới:</b> Lập đỉnh mới kỷ lục sáng nay...</li>
                  <li class="text-sm text-gray-600 hover:text-blue-600 cursor-pointer transition-colors leading-snug">• <b>USD:</b> Tiếp tục đà giảm giá so với các đồng tiền mạnh...</li>
                </ul>
            </div>
          </div>
        </aside>
      )}

    </div>

    <div class="h-8 lg:hidden"></div>

  </body>
</html>
