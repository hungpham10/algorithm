---
import RegionalPriceTable from '../components/gold/RegionalPriceTable.svelte';
import GoldSummary from '../components/gold/GoldSummary.svelte';
import TableHead from '../components/gold/TableHead.astro';
import TableRow from '../components/gold/TableRow.astro';
import Layout from '../components/Layout.astro';

import { FetchIndex } from '../lib/render.js';
import { formatVN } from '../lib/utils.js';

const SHOW_ADS = import.meta.env.SHOW_ADS === 'true';
const SHOW_REGION_TABLE = import.meta.env.SHOW_REGION_TABLE === 'true';

let dataSource = await FetchIndex.load();
const goldSummary = dataSource.summary;
const productIds = dataSource.productIds;

const now = new Date();
const currentDate = `${now.getDate()}/${now.getMonth() + 1}/${now.getFullYear()}`;
const yesterdayDate = `${now.getDate() - 1}/${now.getMonth() + 1}/${now.getFullYear()}`;
---
<Layout title="Bảng giá vàng trực tuyến - Cập nhật liên tục 24h" showAds={SHOW_ADS}>
  <script slot="head" is:inline define:vars={{ productIds }}>
    import { fetchPriceByProductId } from '$lib/fetch.js';
    import { PRICE_EVENT_NAME } from '$lib/schema.js';

    document.addEventListener('DOMContentLoaded', () => {
      fetchPriceByProductId();
      setInterval(() => window.location.reload(), 300000);
    });
  </script>

  <GoldSummary initialData={goldSummary} client:load />

  <div class="mt-4">
    <div class="bg-white border border-gray-200 rounded-md overflow-hidden shadow-sm">
      <header class="p-4 border-b border-gray-100 flex justify-between items-center bg-white">
        <div class="flex items-baseline gap-2">
          <h1 class="text-xl font-bold text-gray-800 tracking-tight">Giá vàng hôm nay</h1>
          <span class="text-gray-400 text-[10px] uppercase tracking-widest font-medium hidden sm:inline">| TRIỆU ĐỒNG/CHỈ</span>
        </div>
        <div class="text-[11px] text-gray-400 font-bold bg-gray-50 px-2 py-1 rounded">{currentDate}</div>
      </header>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <TableHead currentDate={currentDate} yesterdayDate={yesterdayDate} />
          <tbody class="divide-y divide-gray-100">
            {dataSource.tableLargecapEntries.length > 0 ? (
              dataSource.tableLargecapEntries.map(([key, item]) => (
                <TableRow data={item} index={key} />
              ))
            ) : (
              <tr>
                <td colspan="6" class="p-10 text-center text-gray-400 italic">Đang tải dữ liệu thị trường...</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      {SHOW_REGION_TABLE && (
        <div class="border-t border-gray-100">
          <RegionalPriceTable formatVN={formatVN} client:visible />
        </div>
      )}
    </div>
  </div>
</Layout>
