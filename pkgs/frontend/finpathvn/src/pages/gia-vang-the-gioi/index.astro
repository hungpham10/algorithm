---
import Layout from "../../layouts/Layout.astro";
import TradingChart from "../../components/TradingChart.svelte";

const SHOW_ADS = import.meta.env.SHOW_ADS === "true";

const navMenus = [
    { label: "Trang Chủ", href: "/" },
    { label: "Bảng Giá Vàng", href: "/#prices" },
    { label: "Tỷ giá ngân hàng", href: "/#exchange-rates" },
    { label: "Phân Tích Kỹ Thuật", href: "/gia-vang-the-gioi" },
];

const canonicalUrl = "/gia-vang-the-gioi";
---

<Layout
    title="Biểu đồ giá vàng thế giới XAUUSD hôm nay - Phân tích kỹ thuật Real-time"
    description="Xem biểu đồ nến Nhật realtime vàng thế giới XAUUSD. Phân tích kỹ thuật chuyên sâu với biểu đồ nến, chỉ báo RSI, MACD, khối lượng giao dịch, hỗ trợ đa khung thời gian 1m-1M."
    showAds={SHOW_ADS}
    navMenus={navMenus}
    canonicalUrl={canonicalUrl}
>
    <div class="max-w-300 w-full mx-auto px-0 py-6">
        <!-- Breadcrumbs -->
        <nav
            class="flex text-xs text-slate-400 font-semibold mb-6 gap-1.5 items-center px-4"
        >
            <a href="/" class="hover:text-amber-600 transition-colors"
                >Trang chủ</a
            >
            <span>/</span>
            <span class="text-slate-600">Phân tích kỹ thuật</span>
        </nav>

        <!-- Page title -->
        <h1
            class="text-2xl md:text-3xl font-bold text-slate-800 tracking-tight px-4 mb-2"
        >
            Biểu đồ phân tích kỹ thuật vàng thế giới XAUUSD hôm nay
        </h1>
        <p class="text-sm text-slate-500 px-4 mb-6 max-w-3xl">
            Biểu đồ nến realtime XAUUSD — Phân tích xu hướng giá vàng thế giới
            với các chỉ báo kỹ thuật RSI, MACD, Bollinger Bands, Ichimoku. Hỗ
            trợ đa khung thời gian từ 1 phút đến 1 tháng.
        </p>

        <!-- TradingChart component -->
        <TradingChart
            broker="simplefx"
            symbol="XAUUSD"
            title="XAUUSD"
            subtitle="Phân tích kỹ thuật realtime"
            client:load
        />
    </div>
</Layout>
