---
import Layout from "../../layouts/Layout.astro";
import StoreDirectory from "../../components/gold/StoreDirectory.svelte";
import { FetchIndex } from "../../lib/render.js";

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || "https://findaily.vn";
const SHOW_ADS = import.meta.env.SHOW_ADS === "true";

// 1. Tải danh sách tỉnh thành từ GraphQL
const dataSource = await FetchIndex.load();
const allProvinces = dataSource.locationList || [];

// 2. Tải danh sách các tiệm vàng
let stores = [];
try {
    const storesRes = await fetch(
        "https://findaily.vn/api/investing/v2/stores?limit=100",
    );
    if (storesRes.ok) {
        const storesData = await storesRes.json();
        stores = storesData.stores?.data || [];
    }
} catch (e) {
    console.error("Lỗi tải danh sách cửa hàng:", e);
}

// 3. Tải chi nhánh (địa chỉ) của từng cửa hàng song song để xác định tỉnh thành hoạt động
const storesWithDetails = await Promise.all(
    stores.map(async (store) => {
        try {
            const res = await fetch(
                `https://findaily.vn/api/investing/v2/stores/${encodeURIComponent(store.name)}/products`,
            );
            if (res.ok) {
                const detail = await res.json();
                const locations = detail.store?.locations || [];
                const provinces = [
                    ...new Set(
                        locations.map((loc) => loc.province).filter(Boolean),
                    ),
                ];
                return {
                    ...store,
                    locations,
                    provinces,
                };
            }
        } catch (e) {
            console.error(`Lỗi tải chi nhánh cho ${store.name}:`, e);
        }
        return {
            ...store,
            locations: [],
            provinces: [],
        };
    }),
);

// Thiết lập điều hướng nav
const navMenus = [
    { label: "Trang Chủ", href: "/" },
    { label: "Bảng Giá Vàng", href: "/#prices" },
    { label: "Tỷ giá ngân hàng", href: "/#exchange-rates" },
];

const canonicalUrl = `${SITE_URL}/gia-vang`;
---

<Layout
    title="Thông tin các Tiệm Vàng uy tín toàn quốc - FinDaily"
    description="Danh sách các thương hiệu vàng, tiệm vàng lớn uy tín toàn quốc như SJC, DOJI, Bảo Tín Minh Châu, Ancarat... Tra cứu địa chỉ chi nhánh và bảng giá vàng trực tuyến."
    showAds={SHOW_ADS}
    navMenus={navMenus}
    canonicalUrl={canonicalUrl}
>
    <div class="max-w-[1200px] w-full mx-auto px-4 py-8">
        <!-- Hero Section -->
        <div class="mb-10 text-left">
            <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-amber-100 bg-amber-50 text-amber-800 text-xs font-semibold mb-4"
            >
                <span class="text-amber-600 font-bold">✦</span>
                Hệ thống dữ liệu UAT công khai
            </div>
            <h1
                class="text-4xl md:text-5xl font-black text-slate-800 tracking-tight leading-tight"
            >
                Thông tin các <span
                    class="bg-gradient-to-r from-amber-600 to-yellow-500 bg-clip-text text-transparent"
                    >Tiệm Vàng</span
                >
            </h1>
            <p
                class="mt-4 text-sm md:text-base text-slate-500 max-w-2xl leading-relaxed"
            >
                Tra cứu hệ thống chi nhánh cửa hàng, mạng lưới giao dịch và bảng
                giá vàng chi tiết của 40+ thương hiệu kim hoàn uy tín hàng đầu
                tại Việt Nam.
            </p>
        </div>

        <!-- Quick Stats Widget -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
            <div
                class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm"
            >
                <span
                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400 block mb-1"
                    >Thương hiệu</span
                >
                <span
                    class="text-2xl md:text-3xl font-black text-slate-800 font-mono"
                    >{storesWithDetails.length}</span
                >
                <span class="text-xs text-slate-400 block mt-1"
                    >Đang hoạt động</span
                >
            </div>

            <div
                class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm"
            >
                <span
                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400 block mb-1"
                    >Mạng lưới</span
                >
                <span
                    class="text-2xl md:text-3xl font-black text-slate-800 font-mono"
                    >{allProvinces.length}</span
                >
                <span class="text-xs text-slate-400 block mt-1"
                    >Tỉnh thành toàn quốc</span
                >
            </div>

            <div
                class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm"
            >
                <span
                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400 block mb-1"
                    >Dữ liệu</span
                >
                <span
                    class="text-2xl md:text-3xl font-black text-emerald-600 font-mono"
                    >LIVE</span
                >
                <span class="text-xs text-slate-400 block mt-1"
                    >Cập nhật tức thời</span
                >
            </div>

            <div
                class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm"
            >
                <span
                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400 block mb-1"
                    >Độ chính xác</span
                >
                <span
                    class="text-2xl md:text-3xl font-black text-slate-800 font-mono"
                    >100%</span
                >
                <span class="text-xs text-slate-400 block mt-1"
                    >Minh bạch thị trường</span
                >
            </div>
        </div>

        <!-- Interactive Directory Component -->
        <StoreDirectory
            initialStores={storesWithDetails}
            allProvinces={allProvinces}
            client:load
        />
    </div>
</Layout>
