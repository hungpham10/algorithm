---
import TradingChart from '../components/analysis/TradingChart.svelte';
import '../styles/global.css';

const symbols = ['PLX', 'FPT', 'VCB', 'MSN'];
const resolutions = [
    { label: '1 Giờ', value: '1H' },
    { label: '1 Ngày', value: '1D' },
];
---
<div class="controls p-4 flex gap-4">
  <select id="symbolPicker" class="p-2 border rounded">
    {symbols.map(s => <option value={s}>{s}</option>)}
  </select>
</div>
<TradingChart client:load/>
