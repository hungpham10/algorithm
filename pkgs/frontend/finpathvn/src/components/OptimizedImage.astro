---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  format?: 'webp' | 'png' | 'jpg' | 'svg';
  quality?: number;
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  format = 'webp',
  quality = 80
} = Astro.props;

// Chuyển đổi URL gốc thành URL qua proxy wsrv.nl
const proxyUrl = new URL('https://wsrv.nl/');
proxyUrl.searchParams.set('url', src);
if (width) proxyUrl.searchParams.set('w', width.toString());
if (height) proxyUrl.searchParams.set('h', height.toString());
proxyUrl.searchParams.set('output', format);
proxyUrl.searchParams.set('q', quality.toString());
---

<img
  src={proxyUrl.toString()}
  alt={alt}
  class={className}
  loading="lazy"
  decoding="async"
/>
