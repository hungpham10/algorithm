---
// src/layouts/MainLayout.astro
import OptimizedImage from './OptimizedImage.astro';
import '../styles/global.css';

interface MenuItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  showAds?: boolean;
  // Thêm prop menu để truyền từ ngoài vào, mặc định là mảng rỗng
  navMenus?: MenuItem[];
}

const {
  title,
  showAds = false,
  navMenus = [
    { label: 'Giá Vàng', href: '/' },
  ]
} = Astro.props;

const shouldShowNav = navMenus && navMenus.length > 1;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>

  <body class="bg-[#f3f4f6] text-gray-900 antialiased pt-20 md:pt-24 flex flex-col min-h-screen">
    <!-- NAVBAR -->
    <nav class="fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200 shadow-sm">
      <!-- Top Bar: Logo & Status -->
      <div class="h-16 md:h-20 flex items-center border-b border-gray-50">
        <div class="max-w-[1800px] w-full mx-auto px-4 flex items-center justify-between">
          <a href="/" class="flex items-center">
            <OptimizedImage src="https://lighttrading.pp.ua/logo.svg" alt="Logo" class="h-10 w-auto" format="svg" />
          </a>

          <div class="flex items-center gap-4">
            <!-- Hiện menu trên Desktop nếu cần ở góc phải (Optional) -->
            <div class="flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1.5 rounded-full border border-green-100 shadow-sm">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
              </span>
              <span class="text-[10px] font-bold uppercase tracking-wider">Live Data</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Bar: Menu Links (Chỉ hiện nếu > 1 menu) -->
      {shouldShowNav && (
        <div class="bg-white overflow-x-auto no-scrollbar">
          <div class="max-w-[1800px] mx-auto px-4">
            <ul class="flex items-center gap-6 h-10 md:h-12 whitespace-nowrap">
              {navMenus.map((menu) => (
                <li>
                  <a
                    href={menu.href}
                    class="text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors relative group py-2"
                  >
                    {menu.label}
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all group-hover:w-full"></span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </nav>

    <!-- MAIN CONTENT WRAPPER -->
    <div class={showAds ? "max-w-[1850px] w-full mx-auto px-2 md:px-6 flex-grow" : "max-w-[1024px] w-full mx-auto px-4 md:px-10 flex-grow"}>
      <div class="flex flex-row gap-4 items-start justify-between">

        <!-- Sidebar Left... (Giữ nguyên code cũ) -->
        {showAds && (
          <aside class="hidden lg:block w-[160px] sticky top-[7.5rem] self-start flex-shrink-0">
             <!-- Giữ nguyên -->
          </aside>
        )}

        <!-- Slot Chính -->
        <main class="flex-1 min-w-0">
           <!-- Thêm padding-top nếu có thanh menu thứ 2 -->
          <div class={shouldShowNav ? "mt-4" : ""}>
            <slot />
          </div>

          {showAds && (
            <div class="lg:hidden mt-4 bg-white border border-gray-200 rounded-lg p-4 text-center text-gray-400">
                <div class="h-32 bg-gray-50 border-2 border-dashed border-gray-100 rounded flex items-center justify-center italic text-xs">Ads Space Mobile</div>
            </div>
          )}
        </main>

        <!-- Sidebar Right... (Giữ nguyên code cũ) -->
      </div>
    </div>

    <!-- Footer... (Giữ nguyên code cũ) -->
  </body>
</html>
