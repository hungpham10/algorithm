---
// src/layouts/MainLayout.astro
import OptimizedImage from './OptimizedImage.astro';
import '../styles/global.css';

interface Props {
  title: string;
  showAds?: boolean;
}

const { title, showAds = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>

  <body class="bg-[#f3f4f6] text-gray-900 antialiased pt-20 md:pt-24 flex flex-col min-h-screen">
    <!-- NAVBAR -->
    <nav class="fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200 shadow-sm h-16 md:h-20 flex items-center">
      <div class="max-w-[1800px] w-full mx-auto px-4 flex items-center justify-between">
        <a href="/" class="flex items-center">
          <OptimizedImage src="https://lighttrading.pp.ua/logo.svg" alt="Logo" class="h-10 w-auto" format="svg" />
        </a>
        <div class="flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1.5 rounded-full border border-green-100 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
          </span>
          <span class="text-[10px] font-bold uppercase tracking-wider">Live Data</span>
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT WRAPPER -->
    <div class={showAds ? "max-w-[1850px] w-full mx-auto px-2 md:px-6 flex-grow" : "max-w-[1024px] w-full mx-auto px-4 md:px-10 flex-grow"}>
      <div class="flex flex-row gap-4 items-start justify-between">

        <!-- SIDEBAR LEFT ADS -->
        {showAds && (
          <aside class="hidden lg:block w-[160px] sticky top-[5.5rem] self-start flex-shrink-0">
            <div class="bg-white border border-gray-200 rounded-lg p-2 text-center text-gray-400 min-h-[750px] flex flex-col items-center justify-center border-dashed">
                <span class="text-[9px] font-bold text-gray-300 uppercase mb-2">Quảng cáo</span>
                <div class="w-full flex-1 bg-gray-50/50 border border-dashed border-gray-100 rounded flex items-center justify-center text-[10px] italic p-2 text-center text-gray-300">Banner Trái</div>
            </div>
          </aside>
        )}

        <!-- SLOT CHÍNH -->
        <main class="flex-1 min-w-0">
          <slot />

          {showAds && (
            <div class="lg:hidden mt-4 bg-white border border-gray-200 rounded-lg p-4 text-center text-gray-400">
               <div class="h-32 bg-gray-50 border-2 border-dashed border-gray-100 rounded flex items-center justify-center italic text-xs">Ads Space Mobile</div>
            </div>
          )}
        </main>

        <!-- SIDEBAR RIGHT ADS -->
        {showAds && (
          <aside class="hidden lg:block w-[160px] sticky top-[5.5rem] self-start flex-shrink-0">
            <div class="bg-white border border-gray-200 rounded-lg p-2 text-center text-gray-400 min-h-[750px] flex flex-col items-center justify-center border-dashed">
                <span class="text-[9px] font-bold text-gray-300 uppercase mb-2">Quảng cáo</span>
                <div class="w-full flex-1 bg-gray-50/50 border border-dashed border-gray-100 rounded flex items-center justify-center text-[10px] italic p-2 text-center text-gray-300">Banner Phải</div>
            </div>
          </aside>
        )}

      </div>
    </div>

    <!-- FOOTER -->
    <footer class="mt-12 bg-white border-t border-gray-200 pt-10 pb-8">
      <div class="max-w-[1850px] mx-auto px-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8 text-sm text-gray-500">
              <div class="space-y-4">
                  <OptimizedImage src="https://lighttrading.pp.ua/logo.svg" alt="Logo" class="h-10 w-auto" format="svg" />
                  <p class="text-xs">Hệ thống cập nhật giá vàng trực tuyến 24/7.</p>
              </div>
              <div>
                  <h4 class="font-bold text-gray-800 mb-4 uppercase text-[10px] tracking-widest">Thị trường</h4>
                  <ul class="space-y-2 text-xs">
                      <li><a href="#" class="hover:text-blue-600">Giá vàng SJC</a></li>
                      <li><a href="#" class="hover:text-blue-600">Vàng nhẫn 9999</a></li>
                  </ul>
              </div>
              <div>
                  <h4 class="font-bold text-gray-800 mb-4 uppercase text-[10px] tracking-widest">Thông tin</h4>
                  <p class="text-xs italic">© 2026 FinDaily. Thông tin chỉ mang tính chất tham khảo.</p>
              </div>
          </div>
      </div>
    </footer>
  </body>
</html>
