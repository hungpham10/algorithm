---
// src/components/TableHeader.astro
const { currentDate, yesterdayDate } = Astro.props;
---

<thead class="bg-white sticky top-0 z-30 border-b-2 border-gray-200 text-xs md:text-sm">
  <tr class="hidden md:table-row bg-gray-50 border-t border-gray-200">
    <th class="sticky left-0 z-20 bg-gray-50 px-6 py-4 text-left font-semibold text-gray-700 w-1/3 border-r border-gray-200">
      LOẠI VÀNG
    </th>
    <th colspan="2" class="px-4 py-4 text-center font-semibold text-gray-700 border-r border-gray-200">
      HÔM NAY<br>
      <span class="text-xs font-normal text-gray-500">({currentDate})</span>
    </th>
    <th colspan="2" class="px-4 py-4 text-center font-semibold text-gray-500 border-r border-gray-200">
      HÔM QUA<br>
      <span class="text-xs font-normal text-gray-400">({yesterdayDate})</span>
    </th>
    <th class="px-6 py-4 text-center font-semibold text-gray-700">
      XU HƯỚNG<br>
      <span class="text-xs font-normal text-gray-500">(7 ngày)</span>
    </th>
  </tr>

  <tr class="bg-gray-50 text-[11px] md:text-xs font-semibold md:font-medium text-gray-500 border-b border-gray-200">
    <th class="sticky left-0 z-20 bg-gray-50 px-4 md:px-6 py-3 md:py-2.5 text-left text-gray-700 md:text-gray-500 font-semibold md:font-medium border-r border-gray-200">
      <span class="md:hidden">LOẠI VÀNG</span>
    </th>

    <th class="px-4 py-3 md:py-2.5 text-center text-gray-700 md:text-gray-500 border-r border-gray-200">MUA</th>
    <th class="px-4 py-3 md:py-2.5 text-center text-gray-700 md:text-gray-500 border-r border-gray-200">BÁN</th>

    <th class="hidden md:table-cell px-4 py-2.5 text-center border-r border-gray-200">MUA</th>
    <th class="hidden md:table-cell px-4 py-2.5 text-center border-r border-gray-200">BÁN</th>

    <th class="hidden sm:table-cell px-4 md:px-6 py-3 md:py-2.5 text-center text-gray-700 md:text-gray-500">
      <span class="md:hidden">XU HƯỚNG</span>
    </th>
  </tr>
</thead>
