---
const { currentDate, yesterdayDate } = Astro.props;
---

<thead class="bg-gray-100 text-gray-900 sticky top-0 z-30">
  <tr>
    <th rowspan="2" class="sticky left-0 z-40 bg-gray-100 border border-gray-300 p-3 md:p-4 w-1/4 text-center font-bold text-base md:text-lg uppercase tracking-tight shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)]">
      Loại vàng <span class="text-pink-600 text-sm ml-1">⇅</span>
    </th>

    <th colspan="2" class="border border-gray-300 p-3 md:p-4 text-center bg-white font-bold text-base md:text-lg uppercase">
      Hôm nay <br/>
      <span class="text-[12px] text-gray-500 font-medium">({currentDate})</span>
    </th>

    <th colspan="2" class="border border-gray-300 p-3 md:p-4 text-center font-bold text-base md:text-lg uppercase text-gray-600">
      Hôm qua <br/>
      <span class="text-[12px] text-gray-500 font-medium">({yesterdayDate})</span>
    </th>

    <th rowspan="2" class="border border-gray-300 p-3 md:p-4 text-center font-bold text-base md:text-lg uppercase tracking-tight">
      Xu hướng
      <p class="text-[10px] text-gray-500 font-medium mt-1 tracking-normal">(7 ngày) <span class="text-pink-600 ml-1">⇅</span></p>
    </th>
  </tr>

  <tr class="text-[13px] md:text-[15px] font-bold uppercase tracking-wide bg-gray-50">
    <th class="border border-gray-300 p-2 md:p-3 text-center text-gray-900 bg-gray-50">Mua</th>
    <th class="border border-gray-300 p-2 md:p-3 text-center text-gray-900 bg-gray-50">Bán</th>
    <th class="border border-gray-300 p-2 md:p-3 text-center text-gray-500 italic bg-gray-100/50">Mua</th>
    <th class="border border-gray-300 p-2 md:p-3 text-center text-gray-500 italic bg-gray-100/50">Bán</th>
  </tr>
</thead>

<style>
  /* Đảm bảo border không bị biến mất khi sticky */
  thead {
    outline: 1px solid #d1d5db;
  }
</style>
