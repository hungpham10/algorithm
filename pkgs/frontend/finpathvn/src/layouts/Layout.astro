---
// src/layouts/Layout.astro
import OptimizedImage from '../components/OptimizedImage.astro';
import '../styles/global.css';

const ASSET_HOST = import.meta.env.PUBLIC_ASSET_HOST || 'https://findaily.vn';
const GA_TRACKING_ID = import.meta.env.GA_TRACKING_ID;

interface MenuItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  showAds?: boolean;
  navMenus?: MenuItem[];
}

const {
  title,
  description = "Bảng giá vàng trực tuyến SJC, vàng 24K, 9999, nữ trang cập nhật thời gian thực, liên tục 24h nhanh chóng và chính xác nhất.",
  ogImage = "/logo.svg",
  canonicalUrl = Astro.url.href,
  showAds = false,
  navMenus = [
    { label: 'Bảng Giá Vàng', href: '#prices' }
  ]
} = Astro.props;

const shouldShowNav = navMenus && navMenus.length > 1;
const logoUrl = `${ASSET_HOST}/logo.svg`;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {GA_TRACKING_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`}></script>
        <script is:inline define:vars={{ GA_TRACKING_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_TRACKING_ID);
        </script>
      </>
    )}

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="rel" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>

  <body class="flex flex-col min-h-screen font-sans text-foreground bg-white">

    <nav class="sticky top-0 z-50 border-b border-gray-200 bg-white shadow-sm">
      <div class="max-w-[1200px] w-full mx-auto px-4 h-16 md:h-20 flex items-center justify-between gap-4 md:gap-8">

        <a href="/" class="flex items-center gap-2 shrink-0">
          <OptimizedImage
            src={logoUrl}
            alt="Logo FinDaily"
            class="h-9 w-auto"
            format="svg"
          />
        </a>

        {shouldShowNav && (
          <div class="flex-grow overflow-x-auto no-scrollbar hidden sm:block">
            <ul class="flex items-center gap-6 md:gap-8 h-12 whitespace-nowrap justify-start">
              {navMenus.map((menu) => (
                <li> <a
                    href={menu.href}
                    class="text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors relative group py-2 px-1"
                  >
                    {menu.label}
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all group-hover:w-full"></span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-green-100 shrink-0">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
          </span>
          <span class="text-[10px] md:text-xs font-bold uppercase tracking-wider">LIVE DATA</span>
        </div>
      </div>

      {shouldShowNav && (
        <div class="bg-gray-50/50 border-t border-gray-100 overflow-x-auto no-scrollbar sm:hidden">
          <div class="px-4">
            <ul class="flex items-center gap-6 h-10 whitespace-nowrap">
              {navMenus.map((menu) => (
                <li> <a
                    href={menu.href}
                    class="text-xs font-medium text-gray-500 hover:text-blue-600 transition-colors"
                  >
                    {menu.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </nav>

    <div class={showAds ? "w-full mx-auto px-4 md:px-6 flex-grow mt-4" : "max-w-[1200px] w-full mx-auto px-4 md:px-6 flex-grow mt-4"}>
      <div class="flex flex-row gap-6 items-start justify-between">

        {showAds && (
          <aside class="hidden lg:block w-[140px] sticky top-[7.5rem] self-start flex-shrink-0">
            </aside>
        )}

        <main class="flex-1 min-w-0">
          <slot name="hero" />

          <div class="mt-6">
            <slot />
          </div>

          {showAds && (
            <div class="lg:hidden mt-6 bg-white border border-gray-200 rounded-2xl p-6 text-center text-gray-400">
              <div class="h-32 bg-gray-50 border-2 border-dashed border-gray-100 rounded-xl flex items-center justify-center">
                Ads Space Mobile
              </div>
            </div>
          )}
        </main>

        {showAds && (
          <aside class="hidden xl:block w-[260px] sticky top-[7.5rem] self-start flex-shrink-0">
            </aside>
        )}

      </div>
    </div>

    <footer class="mt-auto py-10 text-left text-gray-500 text-sm w-full mx-auto border-gray-200 bg-white">
      <div class="mt-auto border-t border-gray-200 bg-white">
        <div class="mx-auto py-8 px-6 max-w-[1200px]">
          © 2026 FinDaily.vn - Bảng giá vàng trực tuyến
        </div>
      </div>
    </footer>
  </body>
</html>
