---
// src/layouts/Layout.astro
import OptimizedImage from '../components/OptimizedImage.astro';
import '../styles/global.css';

interface MenuItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  showAds?: boolean;
  navMenus?: MenuItem[];
}

const {
  title,
  showAds = false,
  navMenus = [
    { label: 'Bảng Giá Vàng', href: '#prices' }
  ]
} = Astro.props;

const shouldShowNav = navMenus && navMenus.length > 1;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body class="pt-10 flex flex-col min-h-screen font-sans text-foreground bg-white">

    <!-- NAVBAR -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-gray-200 bg-white">
      <div class="max-w-[1200px] w-full mx-auto px-4 h-16 md:h-20 flex items-center justify-between gap-4 md:gap-8">

        <a href="/" class="flex items-center gap-2 shrink-0">
          <img
            src="https://lighttrading.pp.ua/logo.svg"
            class="h-9 w-auto"
          />
        </a>

        {shouldShowNav && (
          <div class="flex-grow overflow-x-auto no-scrollbar hidden sm:block">
            <ul class="flex items-center gap-6 md:gap-8 h-12 whitespace-nowrap justify-start">
              {navMenus.map((menu) => (
                <li key={menu.href}>
                  <a
                    href={menu.href}
                    class="text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors relative group py-2 px-1"
                  >
                    {menu.label}
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all group-hover:w-full"></span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-green-100 shrink-0">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
          </span>
          <span class="text-[10px] md:text-xs font-bold uppercase tracking-wider">LIVE DATA</span>
        </div>
      </div>

      {shouldShowNav && (
        <div class="bg-gray-50/50 border-t border-gray-100 overflow-x-auto no-scrollbar sm:hidden">
          <div class="px-4">
            <ul class="flex items-center gap-6 h-10 whitespace-nowrap">
              {navMenus.map((menu) => (
                <li key={menu.href}>
                  <a
                    href={menu.href}
                    class="text-xs font-medium text-gray-500 hover:text-blue-600 transition-colors"
                  >
                    {menu.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </nav>

    <!-- ==================== MAIN CONTENT ==================== -->
    <div class={showAds ? "w-full mx-auto px-4 md:px-6 flex-grow" : "max-w-[1200px] w-full mx-auto px-4 md:px-6 flex-grow"}>
      <div class="flex flex-row gap-6 items-start justify-between">

        <!-- Sidebar Left - Thu nhỏ -->
        {showAds && (
          <aside class="hidden lg:block w-[140px] sticky top-[7.5rem] self-start flex-shrink-0">
            <!-- Ads trái -->
          </aside>
        )}

        <!-- Main Content -->
        <main class="flex-1 min-w-0">

          <!-- HERO SECTION -->
          <slot name="hero" />

          <!-- Nội dung chính -->
          <div class="mt-6">
            <slot />
          </div>

          <!-- Mobile Ads -->
          {showAds && (
            <div class="lg:hidden mt-6 bg-white border border-gray-200 rounded-2xl p-6 text-center text-gray-400">
              <div class="h-32 bg-gray-50 border-2 border-dashed border-gray-100 rounded-xl flex items-center justify-center">
                Ads Space Mobile
              </div>
            </div>
          )}
        </main>

        <!-- Sidebar Right - Thu nhỏ -->
        {showAds && (
          <aside class="hidden xl:block w-[260px] sticky top-[7.5rem] self-start flex-shrink-0">
            <!-- Ads phải -->
          </aside>
        )}

      </div>
    </div>

    <!-- Footer -->
    <footer class="mt-auto py-8 text-right text-gray-500 text-sm border-t">
      <div class="mx-auto px-6">
        © 2026 FinDaily.vn - Bảng giá vàng trực tuyến
      </div>
    </footer>
  </body>
</html>
